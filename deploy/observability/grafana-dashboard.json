{
  "title": "Event Pipeline",
  "uid": "event-pipeline",
  "tags": ["event-pipeline"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Data source"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Ingest request rate by status code",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (code) (rate(ingest_http_request_duration_seconds_count[1m]))",
          "legendFormat": "{{code}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Ingest latency (p50 / p95 / p99)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ingest_http_request_duration_seconds_bucket{handler=\"events\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ingest_http_request_duration_seconds_bucket{handler=\"events\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ingest_http_request_duration_seconds_bucket{handler=\"events\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Throughput: ingested vs processed",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(ingest_events_total[1m]))",
          "legendFormat": "ingested/s"
        },
        {
          "expr": "sum(rate(worker_events_processed_total[1m]))",
          "legendFormat": "processed/s"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Queue: stream length & pending",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "max(worker_stream_length)", "legendFormat": "stream length" },
        { "expr": "max(worker_stream_pending)", "legendFormat": "pending (unacked)" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Error ratio (5m)",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(ingest_http_request_duration_seconds_count{code=~\"5..\"}[5m])) / sum(rate(ingest_http_request_duration_seconds_count[5m]))"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Redis up (from workers)",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [{ "expr": "min(worker_redis_up)" }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Worker processing time p95 (record + ack)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(worker_process_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
